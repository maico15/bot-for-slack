# Slack app credentials
SLACK_SIGNING_SECRET=your_signing_secret_here
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Bot configuration
CHANNEL_ALLOWLIST=C0123456789,C9876543210     # comma-separated; empty = bot disabled (logs warning)
ESCALATION_USER_ID=U0123456789               # Slack user ID to receive escalation DMs
ESCALATION_KEYWORDS=urgent,critical,outage   # optional: comma-separated regex parts; any match triggers escalation DM

# Server
PORT=3000
